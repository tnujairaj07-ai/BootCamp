# Read Dataset (use the scraped file)
df = pd.read_csv("reviews_books_toscrape.csv")

# -----------------------------------
# Pandas Part
# -----------------------------------

# Remove extra spaces
df["ReviewText"] = df["ReviewText"].astype(str).str.strip()

# Convert to lowercase
df["ReviewText"] = df["ReviewText"].str.lower()

# Keep only reviews containing the word "good"
df = df[df["ReviewText"].str.contains("good", case=False, na=False)]

# Remove duplicate reviews
df = df.drop_duplicates(subset="ReviewText")

print("\nCleaned Data")
print(df.head())

# -----------------------------------
# NumPy Part
# -----------------------------------

# Count number of words in each review
review_length = df["ReviewText"].str.split().apply(len)

# Add review length column
df["ReviewLength"] = review_length

# Ensure StarRating is integer for bincount
df["StarRating"] = df["StarRating"].astype(int)

# Count frequency of Star Ratings
max_rating = df["StarRating"].max()
rating_count = np.bincount(df["StarRating"], minlength=max_rating + 1)

print("\nStar Rating Frequency (index = rating)")
print(rating_count)

