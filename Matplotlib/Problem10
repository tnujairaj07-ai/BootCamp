# Matplotlib Part
# -----------------------------------

plt.figure(figsize=(8, 6))

scatter = plt.scatter(
    df["ReviewLength"],
    df["HelpfulVotes"],
    c=df["StarRating"],
    cmap="RdYlGn",
    s=60
)

plt.colorbar(scatter, label="Star Rating")

plt.xlabel("Review Length")
plt.ylabel("Helpful Votes")
plt.title("Review Length vs Helpful Votes (Books to Scrape)")

